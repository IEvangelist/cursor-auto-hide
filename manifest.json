{
  "manifest_version": 3,
  "name": "Cursor Auto Hide",
  "description": "Hide the mouse pointer while typing in editable controls and restore it as soon as the pointer moves.",
  "version": "0.1.0",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "Cursor Auto Hide",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
